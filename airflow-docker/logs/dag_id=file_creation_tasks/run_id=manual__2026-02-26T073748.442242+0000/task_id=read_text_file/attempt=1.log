from pyspark.sql import SparkSession
from pyspark.sql.functions import col, udf,when,abs,from_utc_timestamp
from pyspark.sql.types import IntegerType, TimestampType
from datetime import datetime, timedelta
 
 
# Create a Spark session
spark = SparkSession.builder.appName("StrategicServicesDGDashboard").config("spark.sql.shuffle.partitions", "2000").config("spark.serializer", "org.apache.spark.serializer.KryoSerializer").getOrCreate()
 
 
holidays = []
holiday_df = spark.sql("SELECT EffectiveIntervalStart, EffectiveIntervalEnd + interval -1 days as EffectiveIntervalEnd FROM dm_dcrm_db.CalendarRuleBase_base where EffectiveIntervalStart is not null")
for i in holiday_df.rdd.collect():
	currDate = i[0]
	while currDate <i[1]:
		holidays.append(currDate.date())
		currDate += timedelta(days=1)
 
 
 
sql_query = """
SELECT DISTINCT source_system,
                loginid,
                servicecode,
                request_id,
                servicenameen,
                servicenamear,
                status,
                (CASE
                     WHEN servicecode='3550' THEN coalesce(payment_date,request_date) + interval -4 hours
                     ELSE request_date + interval -4 hours
                 END) request_date,
                (last_updated_date + interval -4 hours) last_updated_date,
                channel,
                umuser_full_name,
                departmentnameen,
                departmentnamear,
                user_type AS customer_type,
                sub_category
FROM dm_portal_servicerequest_db.tbl_all_system_request_dg_dashboard_new
WHERE servicecode<>'NA'
  AND request_date>='2021-01-01'
"""
 
df = spark.sql(sql_query).persist()
#df.show(truncate=False)
 
 
 
business_start = datetime.strptime("07:30:00", "%H:%M:%S").time()
business_end = datetime.strptime("15:30:00", "%H:%M:%S").time()
business_end_fri = datetime.strptime("12:00:00", "%H:%M:%S").time()
 
 
def calculate_business_minutes(start_timestamp, finish_timestamp):
    # If the Request is in progress, use the current time
    if finish_timestamp is None:
        finish_timestamp = datetime.now()
 
    if start_timestamp is None:
        return 0
 
    total_minutes = 0
    current_timestamp = start_timestamp
 

    while current_timestamp <= finish_timestamp:
        # Exclude weekends and holidays
        if current_timestamp.weekday() == 4:  # Friday
            work_finish = business_end_fri
        else:
            work_finish = business_end
 
 
        if current_timestamp.weekday() == 5 or current_timestamp.weekday() == 6 or current_timestamp.date() in holidays:
            current_timestamp += timedelta(days=1)
            continue
 
        start_time = max(datetime.combine(current_timestamp.date(), business_start), start_timestamp)
        end_time = min(datetime.combine(current_timestamp.date(), work_finish), finish_timestamp)
 
 
 
        if start_time <= end_time:
            diff = end_time - start_time
            total_minutes += (diff.seconds // 60)
 
 
 
        current_timestamp += timedelta(days=1)
 
 
    return total_minutes
 
 
calculate_business_minutes_udf = udf(calculate_business_minutes, IntegerType())
spark.udf.register("calculate_business_minutes_udf", calculate_business_minutes, IntegerType())
 
