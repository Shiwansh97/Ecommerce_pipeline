df_new=spark.sql("select a.source_system,a.loginid,a.servicecode,a.request_id,a.servicenameen as service_name_en,a.servicenamear as service_name_ar,a.status as request_status,a.request_date,a.last_updated_date,a.channel,a.umuser_full_name as customer_user_name,round(abs(nvl(em.employee_time,a.time_taken_minutes)/60/8)) as processing_time,round(abs((a.time_taken_minutes)/60/8)) as completion_time,c.cost,case when a.servicecode in ('3076','3070','3032','3046') then cast(a.sub_category as float) When a.servicecode = '3044' then case when cast(a.sub_category as float)*4 > 20 then 20 else cast(a.sub_category as float)*4 end else nvl(cast(b.service_process_sla as decimal(10,3)),cast(bc.service_process_sla as decimal(10,3))) end as service_process_sla,case when cast((nvl(em.employee_time,a.time_taken_minutes)/60/8) as decimal(10,3)) <= case when a.servicecode in ('3076','3070','3032','3046') then cast(a.sub_category as float) When a.servicecode = '3044' then case when cast(a.sub_category as float)*4 > 20 then 20 else cast(a.sub_category as float)*4 end else nvl(cast(b.service_process_sla as decimal(10,3)),cast(bc.service_process_sla as decimal(10,3))) end then 'True' else 'False' end as within_sla,e.name_en as nationality_en,e.name_ar as nationality_ar,a.departmentnameen as department_name,a.departmentnamear as department_name_ar,f.sectionname as section_name_ar,f.sectionnameen as section_name,g.name_en as sector_name_en,g.name_ar as sector_name_ar,a.customer_type,a.sub_category,a.time_taken_minutes  from requestdata a left join dm_strategic_services_db.service_define_sla_new_final b on a.servicecode=b.servicecode left join dm_strategic_services_db.service_define_sla_category bc on a.servicecode=bc.servicecode and trim(a.sub_category) = trim(bc.description) left join servicecost c on a.servicecode=c.service_id left join dm_um_db.um_users_base d on a.loginid = d.user_id left join dm_um_db.nationality_base e on d.nationality = e.nationality_id left join dm_um_db.dos_services_base f on a.servicecode = f.servicecode left join dm_um_db.sector_sc_base g on f.sectorid = g.sector_id left join dm_portal_servicerequest_db.vw_request_history_employee_final em on a.request_id = em.request_id and a.source_system<>'Labware'")
 
 
